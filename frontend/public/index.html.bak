<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DNS Analyser</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #0B1120; color: #E8EDF5; font-family: 'Inter', system-ui, sans-serif; min-height: 100vh; }
header { background: #0D1526; border-bottom: 1px solid #162030; padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; position: sticky; top: 0; z-index: 10; }
.logo { display: flex; align-items: center; gap: 10px; }
.logo-icon { width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(135deg,#00E5CC,#0066FF); display: flex; align-items: center; justify-content: center; font-size: 16px; }
.logo-text { font-weight: 700; font-size: 16px; }
.logo-sub { font-size: 9px; color: #2A5070; letter-spacing: .8px; font-family: monospace; }
.btn { cursor: pointer; border: none; border-radius: 8px; padding: 8px 16px; font-size: 12px; font-weight: 600; transition: all .15s; font-family: inherit; }
.btn:hover { filter: brightness(1.1); transform: translateY(-1px); }
.btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }
.btn-primary { background: linear-gradient(135deg,#00E5CC,#00AAFF); color: #0B1120; }
.btn-secondary { background: #0D1526; border: 1px solid #1A2B42; color: #6AAACF; }
.btn-danger { background: #FF6B6B22; border: 1px solid #FF6B6B44; color: #FF6B6B; }
.layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 60px); }
.sidebar { background: #0D1526; border-right: 1px solid #162030; padding: 16px 10px; position: sticky; top: 60px; height: calc(100vh - 60px); overflow-y: auto; display: flex; flex-direction: column; gap: 4px; }
.nav-item { padding: 9px 12px; border-radius: 8px; cursor: pointer; font-size: 12px; color: #5A8AAA; border-left: 2px solid transparent; transition: all .15s; display: flex; align-items: center; justify-content: space-between; }
.nav-item:hover { background: #111E30; }
.nav-item.active { background: #0F2040; color: #00E5CC; border-left-color: #00E5CC; }
.badge { padding: 2px 7px; border-radius: 20px; background: #00E5CC22; color: #00E5CC; font-size: 10px; font-weight: 700; }
.main { padding: 24px; overflow-y: auto; }
.card { background: #0D1526; border: 1px solid #162030; border-radius: 13px; padding: 18px; }
.grid-stats { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px,1fr)); gap: 12px; margin-bottom: 20px; }
.stat-card { background: #0D1526; border: 1px solid #162030; border-radius: 12px; padding: 14px 16px; }
.stat-val { font-size: 20px; font-weight: 700; margin: 6px 0 3px; }
.stat-lbl { font-size: 10px; color: #2A5070; }
h2 { font-size: 18px; font-weight: 700; color: #C8D8EA; margin-bottom: 16px; }
.section-title { font-size: 10px; color: #2A5070; font-weight: 700; letter-spacing: .8px; margin-bottom: 10px; }
input, select { background: #0B1520; border: 1px solid #1A2B42; border-radius: 8px; color: #C8D8EA; padding: 8px 12px; font-size: 12px; font-family: inherit; outline: none; }
input:focus { border-color: #00E5CC40; }
.search-row { display: flex; gap: 10px; align-items: center; margin-bottom: 12px; flex-wrap: wrap; }
.row-count { font-size: 11px; color: #3A6080; font-family: monospace; white-space: nowrap; }
table { width: 100%; border-collapse: collapse; font-size: 11px; }
th { padding: 9px 12px; text-align: left; color: #7ABFDF; font-weight: 600; font-size: 11px; background: #0D1526; border-bottom: 2px solid #1A2B42; white-space: nowrap; }
td { padding: 7px 12px; color: #A8BED0; border-bottom: 1px solid #1A2B42; vertical-align: middle; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
tr:hover td { background: #ffffff08; cursor: pointer; }
tr.expanded-row td { background: #142030; }
.expand-panel { background: #0F1E30; border-bottom: 2px solid #00E5CC30; }
.expand-panel td { white-space: normal; max-width: none; }
.expand-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 14px 16px; }
.info-lbl { font-size: 10px; color: #3A6080; font-weight: 600; letter-spacing: .5px; margin-bottom: 3px; }
.info-val { font-size: 11px; color: #A8BED0; line-height: 1.55; word-break: break-all; }
.cat-badge { padding: 2px 8px; border-radius: 20px; font-size: 10px; white-space: nowrap; display: inline-block; }
.risk-H { background: #FF6B6B22; color: #FF6B6B; padding: 2px 7px; border-radius: 20px; font-size: 10px; font-weight: 700; }
.risk-M { background: #F59E0B22; color: #F59E0B; padding: 2px 7px; border-radius: 20px; font-size: 10px; font-weight: 700; }
.risk-L { background: #34D39922; color: #34D399; padding: 2px 7px; border-radius: 20px; font-size: 10px; font-weight: 700; }
.pagination { display: flex; gap: 6px; align-items: center; justify-content: center; margin-top: 12px; flex-wrap: wrap; }
.pager { padding: 5px 10px; border-radius: 6px; border: 1px solid #1A2B42; background: #0D1526; color: #6AAACF; cursor: pointer; font-size: 13px; }
.pager:disabled { opacity: .4; cursor: not-allowed; }
.pager-info { font-size: 11px; color: #3A6080; padding: 0 8px; font-family: monospace; }
.log-box { background: #0B1520; border: 1px solid #162030; border-radius: 10px; overflow: hidden; margin-top: 8px; }
.log-hdr { padding: 8px 12px; border-bottom: 1px solid #162030; font-size: 9px; color: #2A5070; font-weight: 700; letter-spacing: .8px; }
.log-body { height: 160px; overflow-y: auto; padding: 6px 0; }
.log-entry { padding: 3px 12px; display: flex; gap: 8px; font-size: 10px; }
.log-ts { color: #1A3050; font-family: monospace; flex-shrink: 0; }
.log-info { color: #5A9ABF; }
.log-success { color: #00E5CC; }
.log-error { color: #FF6B6B; }
.dot { width: 6px; height: 6px; border-radius: 50%; background: #00E5CC; display: inline-block; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }
.loading { text-align: center; padding: 40px; color: #2A5070; font-size: 13px; }
.sidebar-stats { padding: 10px; font-size: 11px; color: #3A6080; border-top: 1px solid #162030; margin-top: 8px; }
@media(max-width:700px) { .layout{grid-template-columns:1fr} .sidebar{display:none} }
</style>
</head>
<body>
<header>
  <div class="logo">
    <div class="logo-icon">🛡️</div>
    <div>
      <div class="logo-text">DNS Network Analyser</div>
      <div class="logo-sub">NEXTDNS LOG PROCESSOR · HETZNER HOSTED</div>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <button class="btn btn-secondary" onclick="triggerPull()">🔄 Pull NextDNS</button>
    <label for="csvFile" class="btn btn-secondary" style="cursor:pointer">📁 Upload CSV</label>
    <input type="file" id="csvFile" accept=".csv" style="position:absolute;opacity:0;width:1px;height:1px" onchange="uploadCSV(this)">
    <button class="btn btn-primary" onclick="downloadExcel()">⬇️ Excel</button>
    <button class="btn btn-danger" onclick="clearData()">Clear</button>
  </div>
</header>

<div class="layout">
  <div class="sidebar">
    <div class="nav-item active" onclick="showTab('overview',this)">📊 Overview</div>
    <div class="nav-item" onclick="showTab('fulllog',this)">📋 Full Log</div>
    <div class="nav-item" onclick="showTab('persite',this)">🌐 Per Site</div>
    <div class="nav-item" onclick="showTab('background',this)">⚙️ Background</div>
    <div class="nav-item" onclick="showTab('useractivity',this)">👤 User Activity</div>
    <div class="nav-item" onclick="showTab('newsites',this)" id="newSitesNav">🆕 New Sites</div>
    <div class="nav-item" onclick="showTab('settings',this)">⚙️ Settings</div>
    <div class="sidebar-stats" id="sidebarStats"></div>
    <div class="log-box">
      <div class="log-hdr"><span class="dot"></span> SYSTEM LOG</div>
      <div class="log-body" id="logBody"></div>
    </div>
  </div>

  <div class="main">
    <div id="tab-overview">
      <h2>Overview</h2>
      <div id="statsGrid" class="grid-stats"></div>
      <div class="card" style="margin-bottom:16px">
        <div class="section-title">TOP CATEGORIES BY VOLUME</div>
        <div id="topCats"></div>
      </div>
      <div class="card">
        <div class="section-title">⚠️ NOTES</div>
        <div style="font-size:11px;color:#3A6A8A;line-height:1.8">
          <b style="color:#5A9ABF">Activity Types:</b> "Search" = search engines only. "User-Initiated" = direct visits. "Background" = system telemetry, CDN, push, sync.<br>
          <b style="color:#5A9ABF">CDN accuracy:</b> Large CDNs (Akamai, CloudFront) host thousands of sites — classified as Infrastructure/CDN only.<br>
          <b style="color:#5A9ABF">Encryption:</b> DNS-over-HTTPS shows domain only, not specific pages visited.<br>
          <b style="color:#5A9ABF">Privacy risk:</b> High = personal/tracking. Medium = behavioural. Low = technical infrastructure.
        </div>
      </div>
    </div>

    <div id="tab-fulllog" style="display:none">
      <h2>Full Activity Log</h2>
      <div class="search-row">
        <input type="text" id="fulllogSearch" placeholder="Search domain…" style="flex:1;max-width:400px" oninput="debounce(()=>loadFullLog(0),400)()">
        <span class="row-count" id="fulllogCount"></span>
      </div>
      <div style="overflow-x:auto;border-radius:10px;border:1px solid #1A2B42">
        <table><thead><tr><th>Date</th><th>Time</th><th>Root Domain</th><th>Category</th><th>Type</th><th>Risk</th><th>Country</th><th>Status</th></tr></thead>
        <tbody id="fulllogBody"><tr><td colspan="8" class="loading">Click to load…</td></tr></tbody></table>
      </div>
      <div class="pagination" id="fulllogPager"></div>
    </div>

    <div id="tab-persite" style="display:none">
      <h2>Per Site Summary</h2>
      <div class="search-row">
        <input type="text" id="persiteSearch" placeholder="Search domain, owner…" style="flex:1;max-width:260px" oninput="debounce(()=>loadPerSite(),400)()">
        <select id="persiteCat" onchange="persitePage=0;loadPerSite()" style="max-width:210px;background:#0B1520;border:1px solid #1A2B42;border-radius:8px;color:#C8D8EA;padding:8px 10px;font-size:12px;font-family:inherit">
          <option value="">All Categories</option>
          <option>Adult Content</option>
          <option>Advertising / Ad Tech</option>
          <option>AI Services</option>
          <option>Analytics / Monitoring</option>
          <option>Apple Services</option>
          <option>Entertainment / Streaming</option>
          <option>Finance / Banking</option>
          <option>Food / Transport</option>
          <option>Government</option>
          <option>Health</option>
          <option>Infrastructure / CDN</option>
          <option>News / Media</option>
          <option>Pool / Aquatic</option>
          <option>Productivity / Cloud</option>
          <option>Real Estate</option>
          <option>Search / Google</option>
          <option>Shopping / Retail</option>
          <option>Smart Home</option>
          <option>Social Networking</option>
          <option>Telecoms</option>
          <option>Travel / Logistics</option>
          <option>Unknown</option>
          <option>Work / Employment</option>
        </select>
        <span class="row-count" id="persiteCount"></span>
      </div>
      <div style="overflow-x:auto;border-radius:10px;border:1px solid #1A2B42">
        <table><thead><tr><th>Domain</th><th>Category</th><th>Owner</th><th>Risk</th><th>Type</th><th>Visits</th><th>Days</th><th>First Seen</th><th>Last Seen</th></tr></thead>
        <tbody id="persiteBody"><tr><td colspan="9" class="loading">Click tab to load…</td></tr></tbody></table>
      </div>
      <div class="pagination" id="persitePager"></div>
    </div>

    <div id="tab-background" style="display:none">
      <h2>Background Activity</h2>
      <div class="card" style="margin-bottom:14px;font-size:11px;color:#3A6080">System-generated traffic — CDN, push notifications, analytics, OS sync.</div>
      <div class="search-row">
        <input type="text" id="bgSearch" placeholder="Search domain…" style="flex:1;max-width:400px" oninput="debounce(()=>loadBG(0),400)()">
        <span class="row-count" id="bgCount"></span>
      </div>
      <div style="overflow-x:auto;border-radius:10px;border:1px solid #1A2B42">
        <table><thead><tr><th>Date</th><th>Time</th><th>Root Domain</th><th>Category</th><th>Owner</th><th>Risk</th><th>Country</th></tr></thead>
        <tbody id="bgBody"><tr><td colspan="7" class="loading">Click tab to load…</td></tr></tbody></table>
      </div>
      <div class="pagination" id="bgPager"></div>
    </div>

    <div id="tab-useractivity" style="display:none">
      <h2>User Activity</h2>
      <div class="card" style="margin-bottom:14px;font-size:11px;color:#3A6080">Traffic triggered by direct user actions — searches, site visits, app usage.</div>
      <div class="search-row">
        <input type="text" id="userSearch" placeholder="Search domain…" style="flex:1;max-width:400px" oninput="debounce(()=>loadUser(0),400)()">
        <span class="row-count" id="userCount"></span>
      </div>
      <div style="overflow-x:auto;border-radius:10px;border:1px solid #1A2B42">
        <table><thead><tr><th>Date</th><th>Time</th><th>Root Domain</th><th>Type</th><th>Category</th><th>Owner</th><th>Risk</th><th>Country</th><th>Status</th></tr></thead>
        <tbody id="userBody"><tr><td colspan="9" class="loading">Click tab to load…</td></tr></tbody></table>
      </div>
      <div class="pagination" id="userPager"></div>
    </div>

    <div id="tab-newsites" style="display:none">
      <h2>New Sites <span id="newSitesBadge"></span></h2>
      <div class="card" style="margin-bottom:14px;font-size:11px;color:#3A6080">Domains not seen before the most recent upload.</div>
      <div style="overflow-x:auto;border-radius:10px;border:1px solid #1A2B42">
        <table><thead><tr><th>Domain</th><th>Category</th><th>Owner</th><th>Risk</th><th>Purpose</th></tr></thead>
        <tbody id="newSitesBody"><tr><td colspan="5" class="loading">No new sites detected yet</td></tr></tbody></table>
      </div>
    </div>

    <div id="tab-settings" style="display:none">
      <h2>Settings</h2>
      <div class="card" style="max-width:500px">
        <div class="section-title">NEXTDNS API (AUTO-PULL EVERY 6 HOURS)</div>
        <div style="display:flex;flex-direction:column;gap:12px;margin-top:10px">
          <div>
            <div style="font-size:11px;color:#5A9ABF;margin-bottom:5px">NextDNS API Key</div>
            <input type="password" id="apiKey" placeholder="Get from nextdns.io/account" style="width:100%">
          </div>
          <div>
            <div style="font-size:11px;color:#5A9ABF;margin-bottom:5px">Profile ID</div>
            <input type="text" id="profileId" placeholder="e.g. abc123" style="width:100%">
          </div>
          <button class="btn btn-primary" onclick="saveConfig()" style="width:fit-content">Save API Config</button>
          <div style="font-size:10px;color:#3A6080;line-height:1.7">
            API key: <b style="color:#5A9ABF">nextdns.io/account</b> → scroll to API section<br>
            Profile ID: visible in your NextDNS dashboard URL<br>
            Auto-pull runs every 6 hours when configured
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// ─── DOMAIN DB ────────────────────────────────────────────────────────────────
const DB = {
  "apple.com":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Core iOS/macOS — App Store, Siri, Maps, push notifications",data:"Device ID, location, app usage",risk:"M",bg:true},
  "facebook.com":{cat:"Social Networking",owner:"Meta Platforms Inc.",purpose:"Facebook social media — feeds, messaging, notifications",data:"Social graph, messages, location",risk:"H",bg:false},
  "apple-dns.net":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple Private Relay DNS — privacy routing infrastructure",data:"Minimal — privacy service",risk:"L",bg:true},
  "aaplimg.com":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple CDN — App Store artwork, iOS config, Safe Browsing tokens",data:"Device requests",risk:"L",bg:true},
  "com.akadns.net":{cat:"Infrastructure / CDN",owner:"Akamai Technologies",purpose:"Akamai DNS routing — CNAME chaining for Apple and other services",data:"DNS query logs",risk:"L",bg:true},
  "google.com":{cat:"Search / Google",owner:"Google LLC",purpose:"Google Search, Accounts, Maps, Assistant",data:"Search queries, location, browsing history",risk:"H",bg:false},
  "google.com.au":{cat:"Search / Google",owner:"Google LLC",purpose:"Google Australia — localised search and services",data:"Search queries, location",risk:"H",bg:false},
  "bing.com":{cat:"Search / Google",owner:"Microsoft Corporation",purpose:"Microsoft Bing search engine",data:"Search queries, history",risk:"M",bg:false},
  "fbcdn.net":{cat:"Social Networking",owner:"Meta Platforms Inc.",purpose:"Facebook CDN — photos, videos, assets for Facebook and Instagram",data:"CDN logs, device IP",risk:"M",bg:true},
  "facebook.net":{cat:"Advertising / Ad Tech",owner:"Meta Platforms Inc.",purpose:"Facebook SDK — enables Facebook Login and tracking pixel on third-party sites",data:"Cross-site browsing, conversion tracking",risk:"H",bg:true},
  "icloud.com":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple iCloud — backup, photos, Keychain, Find My, Drive",data:"Files, photos, passwords, location",risk:"M",bg:true},
  "icloud-content.com":{cat:"Apple Services",owner:"Apple Inc.",purpose:"iCloud CDN — large file delivery for photos and backups",data:"File access logs",risk:"L",bg:true},
  "cdn-apple.com":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple CDN — software updates and media delivery",data:"Request logs",risk:"L",bg:true},
  "mzstatic.com":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple App Store CDN — app icons, screenshots, media",data:"Request logs",risk:"L",bg:true},
  "apple.map.fastly.net":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple Maps CDN via Fastly — map tile delivery",data:"Location inferred from tiles",risk:"L",bg:true},
  "apple-relay.fastly-edge.com":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple Private Relay via Fastly — iCloud+ privacy proxy",data:"Privacy by design",risk:"L",bg:true},
  "apple.news":{cat:"Apple Services",owner:"Apple Inc.",purpose:"Apple News — news app backend and article delivery",data:"Article requests",risk:"L",bg:false},
  "outlook.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Outlook / Exchange Active Sync — email, calendar, contacts",data:"Email content, calendar, contacts",risk:"M",bg:true},
  "cloud.microsoft":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Cloud — Outlook sync endpoint, Exchange Online",data:"Auth tokens, sync state",risk:"L",bg:true},
  "office.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Office 365 — Outlook, Teams, OneDrive, SharePoint",data:"Documents, collaboration metadata",risk:"M",bg:true},
  "microsoftonline.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Azure AD SSO — OAuth2 for all Microsoft 365 services",data:"Auth tokens, login events",risk:"L",bg:true},
  "live.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Live — @hotmail, @live email, OneDrive",data:"Email, files, account credentials",risk:"M",bg:true},
  "hotmail.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Hotmail / Outlook.com legacy email",data:"Email content, calendar",risk:"M",bg:true},
  "microsoft.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft — docs, software downloads, activation",data:"Software activation ID",risk:"L",bg:true},
  "office.net":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Office CDN — Office suite content delivery",data:"Request logs",risk:"L",bg:true},
  "office365.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Office 365 — subscription verification, licensing",data:"Subscription status, device ID",risk:"L",bg:true},
  "msidentity.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Identity Platform — OAuth2/OIDC auth",data:"Auth tokens",risk:"L",bg:true},
  "skype.com":{cat:"Productivity / Cloud",owner:"Microsoft Corporation",purpose:"Microsoft Skype — voice/video calling",data:"Call logs, contacts, messages",risk:"M",bg:false},
  "tuyaeu.com":{cat:"Smart Home",owner:"Tuya Inc. (China, NYSE: TUYA)",purpose:"Tuya Smart EU servers — ConnectLife appliance connectivity",data:"Device usage, schedules, energy data",risk:"M",bg:true},
  "tuya.com":{cat:"Smart Home",owner:"Tuya Inc.",purpose:"Tuya Smart primary platform — smart home automation",data:"Device usage, automation schedules",risk:"M",bg:true},
  "we-stats.com":{cat:"Smart Home",owner:"Tuya Inc.",purpose:"Tuya/ConnectLife analytics — smart appliance usage stats",data:"Appliance usage, energy data",risk:"L",bg:true},
  "smart321.com":{cat:"Smart Home",owner:"Haier/HiSense (inferred, AU)",purpose:"ConnectLife AU — Haier/HiSense smart home devices",data:"Appliance operation, scheduling",risk:"L",bg:true},
  "connectlife.io":{cat:"Smart Home",owner:"Haier/HiSense",purpose:"ConnectLife — smart home appliance cloud platform",data:"Appliance status, usage patterns",risk:"M",bg:true},
  "spotify.com":{cat:"Entertainment / Streaming",owner:"Spotify AB (Sweden)",purpose:"Spotify music streaming — playback, playlists, podcasts",data:"Listening history, search queries",risk:"M",bg:false},
  "spotifycdn.com":{cat:"Entertainment / Streaming",owner:"Spotify AB",purpose:"Spotify CDN — static assets and media delivery",data:"Request logs",risk:"L",bg:true},
  "scdn.co":{cat:"Entertainment / Streaming",owner:"Spotify AB",purpose:"Spotify audio CDN — delivers actual music streams",data:"Stream access logs",risk:"L",bg:true},
  "tospotify.com":{cat:"Entertainment / Streaming",owner:"Spotify AB",purpose:"Spotify campaign redirect domain",data:"Click tracking",risk:"L",bg:true},
  "netflix.com":{cat:"Entertainment / Streaming",owner:"Netflix Inc. (NASDAQ: NFLX)",purpose:"Netflix — content browsing, playback, downloads",data:"Viewing history, device info, payment",risk:"M",bg:false},
  "nflxvideo.net":{cat:"Entertainment / Streaming",owner:"Netflix Inc.",purpose:"Netflix video CDN — delivers actual video streams",data:"Stream access logs",risk:"L",bg:true},
  "nflxso.net":{cat:"Entertainment / Streaming",owner:"Netflix Inc.",purpose:"Netflix static CDN — UI assets and images",data:"Request logs",risk:"L",bg:true},
  "bamgrid.com":{cat:"Entertainment / Streaming",owner:"The Walt Disney Company",purpose:"Disney+ / BAMTech — Disney streaming infrastructure",data:"Viewing history, device info",risk:"L",bg:true},
  "disneyplus.com":{cat:"Entertainment / Streaming",owner:"The Walt Disney Company",purpose:"Disney+ — Disney, Pixar, Marvel, Star Wars streaming",data:"Viewing history, payment details",risk:"M",bg:false},
  "stan.com.au":{cat:"Entertainment / Streaming",owner:"Nine Entertainment (ASX: NEC)",purpose:"Stan — Australian subscription video streaming",data:"Viewing history, payment details",risk:"M",bg:false},
  "youtube.com":{cat:"Entertainment / Streaming",owner:"Google LLC",purpose:"YouTube — watch, subscribe, YouTube Premium, Shorts",data:"Viewing history, search queries, comments",risk:"M",bg:false},
  "nine.com.au":{cat:"Entertainment / Streaming",owner:"Nine Entertainment (ASX: NEC)",purpose:"Nine Entertainment — 9News, 9Now, SMH, AFR",data:"Reading history, video views",risk:"M",bg:false},
