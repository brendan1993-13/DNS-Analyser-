  "Travel / Logistics":"E3F2FD","Health":"F1F8E9","Telecoms":"F3E5F5",
  "News / Media":"FFF8E1","Unknown":"EEEEEE",
};

function classify(root) {
  if (DB[root]) return DB[root];
  const d = root.toLowerCase();
  if (d.includes('akamai')||d.includes('edgesuite')||d.includes('akadns')||d.includes('edgekey')||d.includes('akamaiedge')||d.includes('akamaihd')) return {cat:'Infrastructure / CDN',owner:'Akamai Technologies',purpose:'Akamai CDN — content delivery network infrastructure',data:'IP address, request timing',risk:'L',bg:true};
  if (d.includes('cloudfront')||d.includes('amazonaws')||d.includes('awsglobalaccelerator')) return {cat:'Infrastructure / CDN',owner:'Amazon Web Services',purpose:'AWS cloud infrastructure — hosting, CDN, or API gateway',data:'Depends on hosted service',risk:'L',bg:true};
  if (d.includes('fastly')) return {cat:'Infrastructure / CDN',owner:'Fastly Inc.',purpose:'Fastly CDN edge cloud delivery',data:'IP address, request logs',risk:'L',bg:true};
  if (d.includes('cloudflare')) return {cat:'Infrastructure / CDN',owner:'Cloudflare Inc.',purpose:'Cloudflare CDN, DDoS protection, or proxy',data:'IP address for DDoS protection',risk:'L',bg:true};
  if (d.includes('googleapis')||d.includes('gstatic')||d.includes('googleusercontent')) return {cat:'Infrastructure / CDN',owner:'Google LLC',purpose:'Google APIs or infrastructure services',data:'API request content',risk:'M',bg:true};
  if ((d.includes('apple')||d.includes('aaplimg'))&&!d.includes('snapple')) return {cat:'Apple Services',owner:'Apple Inc.',purpose:'Apple infrastructure services or CDN',data:'Device requests',risk:'L',bg:true};
  if (d.includes('microsoft')||d.includes('msedge')||d.includes('azurefd')||d.includes('trafficmanager')||d.includes('msftauth')||d.includes('windows.net')) return {cat:'Productivity / Cloud',owner:'Microsoft Corporation',purpose:'Microsoft cloud infrastructure and services',data:'Authentication tokens, service requests',risk:'L',bg:true};
  if (d.includes('facebook')||d.includes('fbcdn')||d.includes('fbsbx')) return {cat:'Social Networking',owner:'Meta Platforms Inc.',purpose:'Meta/Facebook CDN or infrastructure',data:'IP address, CDN logs',risk:'M',bg:true};
  if (d.includes('porn')||d.includes('xvideo')||d.includes('xnxx')||d.includes('chaturbate')||d.includes('stripchats')||d.includes('gayporn')||d.includes('sniffies')||d.includes('trafficjunky')||d.includes('exoclick')) return {cat:'Adult Content',owner:'Unknown Adult Content Provider',purpose:'Adult content platform or associated ad network',data:'Viewing history, device fingerprint',risk:'H',bg:false};
  if (d.endsWith('.gov.au')) return {cat:'Government',owner:'Australian Government',purpose:'Australian Government digital service',data:'Depends on service',risk:'L',bg:false};
  if (d.includes('cdn')||d.includes('static')||d.includes('assets')||d.includes('media')) return {cat:'Infrastructure / CDN',owner:'Unknown CDN/Hosting',purpose:'Content delivery or static asset hosting',data:'Request logs',risk:'L',bg:true};
  return {cat:'Unknown',owner:'Unknown',purpose:'Unclassified — domain not in knowledge base',data:'Unknown',risk:'L',bg:true};
}

const SEARCH_DOMAINS = new Set(['google.com','google.com.au','bing.com','duckduckgo.com','baidu.com','yahoo.com']);
const USER_CATS = new Set(['Social Networking','Shopping / Retail','Entertainment / Streaming','Food / Transport','Travel / Logistics','Government','Pool / Aquatic','Work / Employment','Real Estate','News / Media','Health','Telecoms','AI Services','Adult Content']);

function actType(root, cat) {
  if (SEARCH_DOMAINS.has(root)) return 'Search';
  if (USER_CATS.has(cat)) return 'User-Initiated';
  if (cat==='Finance / Banking'&&!['forter.com','visa.com','stripe.network','nab.edgekey.net','paypalobjects.com','riskified.com'].includes(root)) return 'User-Initiated';
  return 'Background';
}

function isBackground(root, cat) { return actType(root,cat) === 'Background'; }

// ─── UI HELPERS ──────────────────────────────────────────────────────────────
function riskBadge(r){return `<span class="risk-${r||'L'}">${r||'L'}</span>`;}
function catBadge(cat){const col='#'+(CAT_COLORS[cat]||'334466');return `<span class="cat-badge" style="background:${col}40;color:#A8BED0">${cat||'Unknown'}</span>`;}
function mono(t){return `<span style="font-family:monospace;font-size:10px">${t||''}</span>`;}

function log(msg, type='info') {
  const lb = document.getElementById('logBody');
  const ts = new Date().toLocaleTimeString();
  const d = document.createElement('div');
  d.className = 'log-entry';
  d.innerHTML = `<span class="log-ts">${ts}</span><span class="log-${type}" style="margin-left:6px">${msg}</span>`;
  lb.appendChild(d);
  lb.scrollTop = lb.scrollHeight;
  while(lb.children.length > 60) lb.removeChild(lb.firstChild);
}

function debounce(fn, ms) {
  let t;
  return (...args) => { clearTimeout(t); t = setTimeout(()=>fn(...args), ms); };
}

function pagerHTML(page, pages, fn) {
  if (pages <= 1) return '';
  return `<button class="pager" ${page===0?'disabled':''} onclick="${fn}(0)">«</button>
    <button class="pager" ${page===0?'disabled':''} onclick="${fn}(${page-1})">‹</button>
    <span class="pager-info">${page+1} / ${pages}</span>
    <button class="pager" ${page>=pages-1?'disabled':''} onclick="${fn}(${page+1})">›</button>
    <button class="pager" ${page>=pages-1?'disabled':''} onclick="${fn}(${pages-1})">»</button>`;
}

let expandedRow = null;
function toggleExpand(el, row) {
  if (expandedRow) {
    expandedRow.classList.remove('expanded-row');
    const next = expandedRow.nextSibling;
    if (next && next.classList && next.classList.contains('expand-panel')) next.remove();
    if (expandedRow === el) { expandedRow = null; return; }
  }
  expandedRow = el;
  el.classList.add('expanded-row');
  const info = classify(row.root_domain||'');
  const at = actType(row.root_domain||'', info.cat);
  const fields = [
    ['Full Domain', row.domain||row.root_domain||'', true],
    ['Root Domain', row.root_domain||'', true],
    ['Owner / Company', row._owner||info.owner||'Unknown', false],
    ['Category', row._cat||info.cat||'Unknown', false],
    ['Activity Type', at, false],
    ['Privacy Risk', info.risk==='H'?'High — personal/tracking data':info.risk==='M'?'Medium — behavioural data':'Low — technical infrastructure', false],
    ['Purpose & Description', row._purpose||info.purpose||'No description available', false],
    ['Data Collected', row._data||info.data||'Unknown', false],
    ...(row.timestamp?[['Timestamp', row.timestamp, true]]:[]),
    ...(row.query_type?[['Query Type', row.query_type, false]]:[]),
    ...(row.destination_country?[['Country', row.destination_country, false]]:[]),
    ...(row.status?[['Status', row.status, false]]:[]),
    ...(row.reasons?[['Block Reason', row.reasons, false]]:[]),
    ...(row.first_seen?[['First Seen', row.first_seen, false]]:[]),
    ...(row.last_seen?[['Last Seen', row.last_seen, false]]:[]),
    ...(row.total_visits!==undefined?[['Total Visits', String(row.total_visits), false]]:[]),
    ...(row.unique_days!==undefined?[['Unique Days', String(row.unique_days), false]]:[]),
  ];
  const colCount = el.cells.length;
  const tr = document.createElement('tr');
  tr.className = 'expand-panel';
  tr.innerHTML = `<td colspan="${colCount}"><div class="expand-grid">${
    fields.map(([l,v,m])=>`<div style="${l==='Purpose & Description'||l==='Data Collected'?'grid-column:1/-1':''}">
      <div class="info-lbl">${l}</div><div class="info-val${m?' mono':''}">${v}</div></div>`).join('')
  }</div></td>`;
  el.insertAdjacentElement('afterend', tr);
}

// ─── TAB NAVIGATION ──────────────────────────────────────────────────────────
const tabLoaded = {};
function showTab(id, el) {
  document.querySelectorAll('[id^="tab-"]').forEach(t=>t.style.display='none');
  document.getElementById('tab-'+id).style.display='';
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  if (!tabLoaded[id]) {
    tabLoaded[id] = true;
    if (id==='fulllog') loadFullLog(0);
    if (id==='persite') loadPerSite();
    if (id==='background') loadBG(0);
    if (id==='useractivity') loadUser(0);
  }
}

// ─── OVERVIEW ────────────────────────────────────────────────────────────────
async function loadOverview() {
  log('Loading summary…');
  try {
    const res = await fetch('/api/summary');
    const d = await res.json();
    const sg = document.getElementById('statsGrid');
    const stats = [
      {l:'Total Queries',v:d.count.toLocaleString(),i:'🔍',c:'#00E5CC'},
      {l:'Unique Domains',v:d.domains.toLocaleString(),i:'🌐',c:'#00AAFF'},
      {l:'Days Covered',v:d.days.toLocaleString(),i:'📅',c:'#A78BFA'},
      {l:'Blocked',v:(d.blocked||0).toLocaleString(),i:'🚫',c:'#FF6B6B'},
    ];
    sg.innerHTML = stats.map(s=>`<div class="stat-card"><div style="font-size:18px">${s.i}</div><div class="stat-val" style="color:${s.c}">${s.v}</div><div class="stat-lbl">${s.l}</div></div>`).join('');

    // Category totals from top domains
    const cc={};
    d.topDomains.forEach(({domain,count})=>{
      const info=classify(domain);
      cc[info.cat]=(cc[info.cat]||0)+count;
    });
    const top=Object.entries(cc).sort((a,b)=>b[1]-a[1]).slice(0,8);
    const total=d.count||1;
    document.getElementById('topCats').innerHTML=top.map(([cat,count])=>{
      const pct=Math.round(count/total*100);
      const col='#'+(CAT_COLORS[cat]||'334466');
      return `<div style="margin-bottom:10px">
        <div style="display:flex;justify-content:space-between;margin-bottom:4px">
          <span style="font-size:12px;color:#A8BED0">${cat}</span>
          <span style="font-size:10px;color:#3A6080;font-family:monospace">${count.toLocaleString()} (${pct}%)</span>
        </div>
        <div style="height:5px;border-radius:3px;background:#162030;overflow:hidden">
          <div style="height:100%;border-radius:3px;width:${Math.max(pct,.3)}%;background:${col};opacity:.85"></div>
        </div></div>`;
    }).join('');

    document.getElementById('sidebarStats').innerHTML = `
      <div style="font-size:10px;line-height:1.9">
        <span style="color:#00E5CC;font-weight:700">${d.count.toLocaleString()}</span> rows<br>
        <span style="color:#00AAFF;font-weight:700">${d.domains}</span> domains<br>
        <span style="color:#A78BFA;font-weight:700">${d.days}</span> days
      </div>`;

    log(`✅ ${d.count.toLocaleString()} rows · ${d.domains} domains · ${d.days} days`, 'success');
  } catch(e) { log(`❌ ${e.message}`, 'error'); }
}

// ─── FULL LOG ────────────────────────────────────────────────────────────────
async function loadFullLog(page) {
  const q = document.getElementById('fulllogSearch')?.value||'';
  const res = await fetch(`/api/rows?page=${page}&limit=200${q?'&q='+encodeURIComponent(q):''}`);
  const d = await res.json();
  document.getElementById('fulllogCount').textContent = `${d.count.toLocaleString()} rows`;
  const tb = document.getElementById('fulllogBody');
  tb.innerHTML = '';
  if (!d.rows.length) { tb.innerHTML='<tr><td colspan="8" class="loading">No results</td></tr>'; return; }
  d.rows.forEach(r => {
    const info = classify(r.root_domain||'');
    const at = actType(r.root_domain||'', info.cat);
    const date = (r.timestamp||'').split('T')[0]||'';
    const time = (r.timestamp||'').split('T')[1]?.substring(0,8)||'';
    const tr = document.createElement('tr');
    tr.onclick = ()=>toggleExpand(tr, r);
    tr.innerHTML = `<td>${mono(date)}</td><td>${mono(time)}</td><td>${mono(r.root_domain||'')}</td><td>${catBadge(info.cat)}</td><td><span style="font-size:10px;color:${at==='Background'?'#4A7FA5':at==='Search'?'#F59E0B':'#34D399'}">${at}</span></td><td>${riskBadge(info.risk)}</td><td><span style="font-size:10px;color:#3A6080">${r.destination_country||''}</span></td><td>${r.status?`<span style="font-size:10px;color:${r.status==='blocked'?'#FF6B6B':'#34D399'}">${r.status}</span>`:''}</td>`;
    tb.appendChild(tr);
  });
  document.getElementById('fulllogPager').innerHTML = pagerHTML(page, d.pages, 'loadFullLog');
}

// ─── PER SITE ────────────────────────────────────────────────────────────────
let persiteData = null, persitePage = 0;
const PERSITE_PAGE = 100;
async function loadPerSite() {
  const q = document.getElementById('persiteSearch')?.value||'';
  const cat = document.getElementById('persiteCat')?.value||'';
  const params = new URLSearchParams();
  if(q) params.set('q',q);
  if(cat) params.set('cat',cat);
  const res = await fetch('/api/persite'+(params.toString()?'?'+params.toString():''));
  const d = await res.json();
  persiteData = d.rows.map(r => {
    const info = classify(r.root_domain||'');
    return {...r, _cat:info.cat, _owner:info.owner, _purpose:info.purpose, _data:info.data, _risk:info.risk, _at:actType(r.root_domain||'',info.cat)};
  });
  persitePage = 0;
  renderPerSite();
}
function renderPerSite() {
  const rows = persiteData||[];
  const start = persitePage * PERSITE_PAGE;
  const slice = rows.slice(start, start + PERSITE_PAGE);
  document.getElementById('persiteCount').textContent = `${rows.length.toLocaleString()} domains`;
  const tb = document.getElementById('persiteBody');
  tb.innerHTML = '';
  slice.forEach(r => {
    const tr = document.createElement('tr');
    tr.onclick = ()=>toggleExpand(tr, r);
    tr.innerHTML = `<td>${mono(r.root_domain||'')}</td><td>${catBadge(r._cat)}</td><td><span style="font-size:10px;color:#7AAACF">${r._owner||''}</span></td><td>${riskBadge(r._risk)}</td><td><span style="font-size:10px;color:${r._at==='Background'?'#4A7FA5':'#34D399'}">${r._at}</span></td><td><span style="font-family:monospace;font-size:12px;font-weight:700;color:#00E5CC">${(r.total_visits||0).toLocaleString()}</span></td><td><span style="font-family:monospace;font-size:11px;color:#00AAFF">${r.unique_days||0}</span></td><td>${mono(r.first_seen||'')}</td><td>${mono(r.last_seen||'')}</td>`;
    tb.appendChild(tr);
  });
  const pages = Math.ceil(rows.length/PERSITE_PAGE);
  document.getElementById('persitePager').innerHTML = pagerHTML(persitePage, pages, 'persiteGoPage');
}
function persiteGoPage(p) { persitePage=p; renderPerSite(); }

// ─── BACKGROUND ──────────────────────────────────────────────────────────────
async function loadBG(page) {
  const q = document.getElementById('bgSearch')?.value||'';
  const res = await fetch(`/api/rows?page=${page}&limit=200&tab=bg${q?'&q='+encodeURIComponent(q):''}`);
  const d = await res.json();
  // Filter client-side for background
  const bgRows = d.rows.filter(r=>{ const info=classify(r.root_domain||''); return isBackground(r.root_domain||'',info.cat); });
  document.getElementById('bgCount').textContent = `${d.count.toLocaleString()} rows (showing background)`;
  const tb = document.getElementById('bgBody');
  tb.innerHTML = '';
  bgRows.forEach(r => {
    const info = classify(r.root_domain||'');
    const date = (r.timestamp||'').split('T')[0]||'';
    const time = (r.timestamp||'').split('T')[1]?.substring(0,8)||'';
    const tr = document.createElement('tr');
    tr.onclick = ()=>toggleExpand(tr, {...r, _owner:info.owner, _purpose:info.purpose, _data:info.data});
    tr.innerHTML = `<td>${mono(date)}</td><td>${mono(time)}</td><td>${mono(r.root_domain||'')}</td><td>${catBadge(info.cat)}</td><td><span style="font-size:10px;color:#7AAACF">${info.owner||''}</span></td><td>${riskBadge(info.risk)}</td><td><span style="font-size:10px;color:#3A6080">${r.destination_country||''}</span></td>`;
    tb.appendChild(tr);
  });
  document.getElementById('bgPager').innerHTML = pagerHTML(page, d.pages, 'loadBG');
}

// ─── USER ACTIVITY ───────────────────────────────────────────────────────────
async function loadUser(page) {
  const q = document.getElementById('userSearch')?.value||'';
  const res = await fetch(`/api/rows?page=${page}&limit=200${q?'&q='+encodeURIComponent(q):''}`);
  const d = await res.json();
  const userRows = d.rows.filter(r=>{ const info=classify(r.root_domain||''); return !isBackground(r.root_domain||'',info.cat); });
  document.getElementById('userCount').textContent = `${d.count.toLocaleString()} rows (showing user-initiated)`;
  const tb = document.getElementById('userBody');
  tb.innerHTML = '';
  userRows.forEach(r => {
    const info = classify(r.root_domain||'');
    const at = actType(r.root_domain||'', info.cat);
    const date = (r.timestamp||'').split('T')[0]||'';
    const time = (r.timestamp||'').split('T')[1]?.substring(0,8)||'';
    const tr = document.createElement('tr');
    tr.onclick = ()=>toggleExpand(tr, {...r, _owner:info.owner, _purpose:info.purpose, _data:info.data});
    tr.innerHTML = `<td>${mono(date)}</td><td>${mono(time)}</td><td>${mono(r.root_domain||'')}</td><td><span style="font-size:10px;font-weight:600;color:${at==='Search'?'#F59E0B':'#34D399'}">${at}</span></td><td>${catBadge(info.cat)}</td><td><span style="font-size:10px;color:#7AAACF">${info.owner||''}</span></td><td>${riskBadge(info.risk)}</td><td><span style="font-size:10px;color:#3A6080">${r.destination_country||''}</span></td><td>${r.status?`<span style="font-size:10px;color:${r.status==='blocked'?'#FF6B6B':'#34D399'}">${r.status}</span>`:''}</td>`;
    tb.appendChild(tr);
  });
  document.getElementById('userPager').innerHTML = pagerHTML(page, d.pages, 'loadUser');
}

// ─── ACTIONS ─────────────────────────────────────────────────────────────────
async function uploadCSV(input) {
  const file = input.files[0];
  if (!file) return;
  log(`Uploading ${file.name}…`);
  const form = new FormData();
  form.append('file', file);
  try {
    const res = await fetch('/api/upload', { method:'POST', body:form });
    const d = await res.json();
    if (d.error) { log(`❌ ${d.error}`, 'error'); return; }
    log(`✅ Added ${d.added.toLocaleString()} rows (${d.skipped.toLocaleString()} skipped, ${d.total.toLocaleString()} total)`, 'success');
    tabLoaded.fulllog=false; tabLoaded.persite=false; tabLoaded.background=false; tabLoaded.useractivity=false;
    persiteData=null;
    loadOverview();
  } catch(e) { log(`❌ Upload failed: ${e.message}`, 'error'); }
}

async function triggerPull() {
  log('Pulling from NextDNS API…');
  try {
    const res = await fetch('/api/pull', {method:'POST'});
    const d = await res.json();
    if (d.error) { log(`❌ ${d.error}`, 'error'); return; }
    log(`✅ Added ${d.added.toLocaleString()} rows (total ${d.total.toLocaleString()})`, 'success');
    tabLoaded.fulllog=false; tabLoaded.persite=false; tabLoaded.background=false; tabLoaded.useractivity=false;
    persiteData=null;
    loadOverview();
  } catch(e) { log(`❌ Pull failed: ${e.message}`, 'error'); }
}

async function saveConfig() {
  const apiKey = document.getElementById('apiKey').value.trim();
  const profileId = document.getElementById('profileId').value.trim();
  if (!apiKey||!profileId) { log('Enter both API key and Profile ID', 'error'); return; }
  await fetch('/api/config', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({apiKey,profileId})});
  log('✅ API config saved — auto-pull active every 6 hours', 'success');
}

function downloadExcel() {
  log('Requesting Excel export…');
  window.location.href = '/api/export';
}

async function clearData() {
  if (!confirm('Clear ALL data from server? This cannot be undone.')) return;
  await fetch('/api/rows', {method:'DELETE'});
  persiteData=null;
  Object.keys(tabLoaded).forEach(k=>delete tabLoaded[k]);
  log('All data cleared', 'info');
  loadOverview();
}

// ─── INIT ────────────────────────────────────────────────────────────────────
loadOverview();
</script>
</body>
</html>
